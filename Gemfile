source 'https://rubygems.org'

# GitHub Pages 기본 빌드 환경과 같은 의존성 묶음을 사용한다.
# 현재 GitHub Pages는 github-pages 232와 Jekyll 3.10.0 조합으로 빌드된다.
gem 'github-pages', '~> 232', group: :jekyll_plugins

# Ruby 3.0 이상에서 로컬 `jekyll serve`를 실행할 때 필요한 서버 어댑터.
gem 'webrick'

# Windows 로컬 Ruby 환경에서 timezone 데이터를 찾기 위해 필요하다.
gem 'tzinfo-data'
